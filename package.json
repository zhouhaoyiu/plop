{
  "name": "plop-monorepo",
  "version": "0.0.0",
  "private": true,
  "workspaces": {
    "packages": [
      "packages/*"
    ]
  },
  "type": "module",
  "scripts": {
    "test": "turbo run test --parallel",
    "format": "prettier --write .",
    "lint": "eslint .",
    "plop": "node ./packages/plop/bin/plop.js",
    "prepare": "husky"
  },
  "bugs": {
    "url": "https://github.com/plopjs/plop/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/plopjs/plop.git"
  },
  "homepage": "https://plopjs.com",
  "license": "MIT",
  "engines": {
    "node": ">=20.19.0"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.5.2",
    "@changesets/cli": "^2.29.8",
    "@eslint/js": "^9.39.2",
    "@vitest/eslint-plugin": "^1.6.6",
    "eslint": "^9.39.2",
    "globals": "^17.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.8.1",
    "turbo": "^2.7.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.53.1"
  },
  "resolutions": {
    "glob@npm:^10.2.2": "npm:10.5.0",
    "handlebars@npm:^4.7.8": "npm:4.7.9",
    "istanbul-lib-report@npm:^3.0.0": "npm:3.0.1",
    "node-gyp@npm:latest": "npm:10.3.1",
    "postcss@npm:^8.5.6": "npm:8.5.10",
    "rollup@npm:^4.43.0": "npm:4.59.0",
    "semver@npm:^6.0.0": "npm:6.3.1",
    "semver@npm:^7.3.5": "npm:7.7.3",
    "tar@npm:^6.1.11": "npm:7.5.19",
    "tar@npm:^6.2.1": "npm:7.5.19",
    "vite@npm:^6.0.0 || ^7.0.0": "npm:7.3.5"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "prettier --write",
      "eslint --cache --fix"
    ]
  },
  "packageManager": "yarn@4.9.4"
}
